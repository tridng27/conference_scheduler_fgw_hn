{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block body %}
<div class="card auth-card">
    <h1>Sign In</h1>
    <p style="color: var(--muted); margin-top: 0;">Use your account to access conference data.</p>

    {% if error %}
        <div class="flash flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
    {% endif %}

    <form method="post">
        <label for="username">Email</label>
        <input type="email" value="{{ last_username }}" name="_username" id="username" autocomplete="email" required autofocus>

        <label for="password">Password</label>
        <input type="password" name="_password" id="password" autocomplete="current-password" required>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="actions" style="margin-top: 10px;">
            <button class="btn" type="submit">Login</button>
            <a class="btn btn-secondary" href="{{ path('app_register') }}">Create account</a>
        </div>
    </form>
</div>
{% endblock %}

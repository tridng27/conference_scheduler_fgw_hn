{% extends 'base.html.twig' %}

{% block title %}Session Schedule{% endblock %}

{% block body %}
<div class="card">
    <div class="actions">
        <h1 style="margin: 0;">Conference Session Schedule</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a class="btn" href="{{ path('app_session_new') }}">Create Session</a>
        {% endif %}
    </div>

    <form method="get" class="actions" style="margin-top: 12px;">
        <div style="min-width: 220px;">
            <label for="conference-filter">Conference</label>
            <select id="conference-filter" name="conference">
                <option value="0">All conferences</option>
                {% for conference in conferences %}
                    <option value="{{ conference.id }}" {% if selected_conference == conference.id %}selected{% endif %}>
                        {{ conference.name }}
                    </option>
                {% endfor %}
            </select>
        </div>
        <div style="min-width: 220px;">
            <label for="date-filter">Date</label>
            <input id="date-filter" type="date" name="date" value="{{ selected_date }}">
        </div>
        <div class="actions" style="margin-top: 22px;">
            <button class="btn" type="submit">Apply</button>
            <a class="btn btn-secondary" href="{{ path('app_session_index') }}">Reset</a>
        </div>
    </form>

    <table>
        <thead>
            <tr>
                <th>Time</th>
                <th>Session</th>
                <th>Conference</th>
                <th>Room(s)</th>
                <th>Speaker(s)</th>
                <th>Track</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for session in sessions %}
            <tr>
                <td>{{ session.startTime ? session.startTime|date('Y-m-d H:i') : '-' }} - {{ session.endTime ? session.endTime|date('H:i') : '-' }}</td>
                <td>
                    <strong>{{ session.title }}</strong><br>
                    <small style="color: var(--muted);">{{ session.sessionType }} | Capacity {{ session.capacity ?? session.maxAttendees }}</small>
                </td>
                <td>{{ session.conference ? session.conference.name : '-' }}</td>
                <td>
                    {% for room in session.rooms %}
                        {{ room.name }}{% if not loop.last %}, {% endif %}
                    {% else %}
                        -
                    {% endfor %}
                </td>
                <td>
                    {% for speaker in session.speakers %}
                        {{ speaker.name }}{% if not loop.last %}, {% endif %}
                    {% else %}
                        -
                    {% endfor %}
                </td>
                <td>{{ session.track ?? '-' }}</td>
                <td>{{ session.status }}</td>
                <td>
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="actions">
                            <a class="btn btn-secondary" href="{{ path('app_session_edit', {id: session.id}) }}">Edit</a>
                            <form class="inline" method="post" action="{{ path('app_session_delete', {id: session.id}) }}" onsubmit="return confirm('Delete this session?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_session_' ~ session.id) }}">
                                <button class="btn btn-danger" type="submit">Delete</button>
                            </form>
                        </div>
                    {% else %}
                        <span style="color: var(--muted);">View only</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr><td colspan="8">No sessions match the selected schedule filters.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

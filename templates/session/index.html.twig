{% extends 'base.html.twig' %}

{% block title %}Sessions{% endblock %}

{% block body %}
<div class="card">
    <div class="actions">
        <h1 style="margin: 0;">Sessions</h1>
        <a class="btn" href="{{ path('app_session_new') }}">New Session</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Conference</th>
                <th>Time</th>
                <th>Status</th>
                <th>Speakers</th>
                <th>Rooms</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for session in sessions %}
            <tr>
                <td>{{ session.id }}</td>
                <td>{{ session.title }}</td>
                <td>{{ session.conference ? session.conference.name : '-' }}</td>
                <td>{{ session.startTime ? session.startTime|date('Y-m-d H:i') : '-' }} to {{ session.endTime ? session.endTime|date('Y-m-d H:i') : '-' }}</td>
                <td>{{ session.status }}</td>
                <td>{{ session.speakers|length }}</td>
                <td>{{ session.rooms|length }}</td>
                <td>
                    <div class="actions">
                        <a class="btn btn-secondary" href="{{ path('app_session_edit', {id: session.id}) }}">Edit</a>
                        <form class="inline" method="post" action="{{ path('app_session_delete', {id: session.id}) }}" onsubmit="return confirm('Delete this session?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_session_' ~ session.id) }}">
                            <button class="btn btn-danger" type="submit">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="8">No sessions found.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Speakers{% endblock %}

{% block body %}
<div class="card">
    <div class="actions">
        <h1 style="margin: 0;">Speakers</h1>
        <a class="btn" href="{{ path('app_speaker_new') }}">New Speaker</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Company</th>
                <th>User</th>
                <th>Sessions</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for speaker in speakers %}
            <tr>
                <td>{{ speaker.id }}</td>
                <td>{{ speaker.name }}</td>
                <td>{{ speaker.email }}</td>
                <td>{{ speaker.company }}</td>
                <td>{{ speaker.user ? speaker.user.email : '-' }}</td>
                <td>{{ speaker.sessions|length }}</td>
                <td>
                    <div class="actions">
                        <a class="btn btn-secondary" href="{{ path('app_speaker_edit', {id: speaker.id}) }}">Edit</a>
                        <form class="inline" method="post" action="{{ path('app_speaker_delete', {id: speaker.id}) }}" onsubmit="return confirm('Delete this speaker?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_speaker_' ~ speaker.id) }}">
                            <button class="btn btn-danger" type="submit">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="7">No speakers found.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

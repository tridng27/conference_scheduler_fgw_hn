{% extends 'base.html.twig' %}

{% block title %}Edit Speaker{% endblock %}

{% block body %}
<div class="card">
    <h1>Edit Speaker #{{ speaker.id }}</h1>

    {{ form_start(form) }}
        {{ form_widget(form) }}
        <div class="actions" style="margin-top: 12px;">
            <button class="btn" type="submit">Update</button>
            <a class="btn btn-secondary" href="{{ path('app_speaker_index') }}">Back</a>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}

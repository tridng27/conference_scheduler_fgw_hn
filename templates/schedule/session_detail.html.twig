{% extends 'base.html.twig' %}

{% block title %}Session Details - {{ session.title }}{% endblock %}

{% block body %}
    <div style="margin-bottom: 24px;">
        <a href="{{ path('app_schedule') }}" style="display: inline-flex; align-items: center; gap: 6px; color: #0b4f6c; text-decoration: none; font-size: 14px; margin-bottom: 16px; padding: 6px 12px; border-radius: 6px; transition: all 0.2s;  hover-background: #f0f7ff;">
            ← Back to Schedule
        </a>
    </div>

    <div class="card" style="background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); border: 1px solid #e5e7eb;">
        <!-- Header Section -->
        <div style="padding-bottom: 20px; border-bottom: 2px solid #e5e7eb; margin-bottom: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 16px;">
                <div style="flex: 1;">
                    <h1 style="margin: 0 0 12px 0; color: #0b4f6c; font-size: 28px; font-weight: 700;">📋 {{ session.title }}</h1>
                    <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-top: 12px;">
                        <div style="padding: 6px 12px; background: #f0f7ff; border-left: 3px solid #0b4f6c; border-radius: 4px;">
                            <div style="font-size: 12px; color: #265f7d; font-weight: 600;">START TIME</div>
                            <div style="font-size: 14px; color: #0b4f6c; font-weight: 600; margin-top: 2px;">{{ session.startTime|date('M d, Y H:i') }}</div>
                        </div>
                        <div style="padding: 6px 12px; background: #f0f7ff; border-left: 3px solid #0b4f6c; border-radius: 4px;">
                            <div style="font-size: 12px; color: #265f7d; font-weight: 600;">END TIME</div>
                            <div style="font-size: 14px; color: #0b4f6c; font-weight: 600; margin-top: 2px;">{{ session.endTime|date('M d, Y H:i') }}</div>
                        </div>
                        <div style="padding: 6px 12px; background: #fef3c7; border-left: 3px solid #ffb703; border-radius: 4px;">
                            <div style="font-size: 12px; color: #92400e; font-weight: 600;">TYPE</div>
                            <div style="font-size: 14px; color: #b45309; font-weight: 600; margin-top: 2px;">{{ session.sessionType ?? 'PRESENTATION' }}</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 320px; gap: 28px;">
            <!-- Main Content -->
            <div>
                <!-- Description Section -->
                <div style="margin-bottom: 28px;">
                    <h3 style="margin: 0 0 12px 0; padding: 8px 12px; background: #f0f7ff; border-left: 4px solid #0b4f6c; border-radius: 4px; color: #0b4f6c; font-size: 15px; font-weight: 700;">
                        📝 Description
                    </h3>
                    <p style="margin: 0; padding: 16px 12px; background: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; color: #4b5563; line-height: 1.6;">
                        {% if session.description %}{{ session.description }}{% else %}<em style="color: #9ca3af;">No description provided</em>{% endif %}
                    </p>
                </div>

                <!-- Session Details Grid -->
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 28px;">
                    <div style="padding: 12px; background: linear-gradient(135deg, #f8fafc 0%, #eef7ff 100%); border: 1px solid #d1dce6; border-radius: 8px;">
                        <div style="font-size: 12px; font-weight: 600; color: #265f7d; text-transform: uppercase; letter-spacing: 0.5px;">Max Attendees</div>
                        <div style="font-size: 20px; font-weight: 700; color: #0b4f6c; margin-top: 6px;">{% if session.maxAttendees %}{{ session.maxAttendees }}{% else %}Unlimited{% endif %}</div>
                    </div>
                    <div style="padding: 12px; background: linear-gradient(135deg, #f8fafc 0%, #eef7ff 100%); border: 1px solid #d1dce6; border-radius: 8px;">
                        <div style="font-size: 12px; font-weight: 600; color: #265f7d; text-transform: uppercase; letter-spacing: 0.5px;">Status</div>
                        <div style="font-size: 16px; font-weight: 700; color: #0b4f6c; margin-top: 6px; display: inline-block; padding: 4px 8px; background: #dbeafe; color: #0369a1; border-radius: 4px;">
                            {{ session.status ?? 'SCHEDULED' }}
                        </div>
                    </div>
                </div>

                <!-- Speakers Section -->
                <div style="margin-bottom: 28px;">
                    <h3 style="margin: 0 0 12px 0; padding: 8px 12px; background: #f0f7ff; border-left: 4px solid #0b4f6c; border-radius: 4px; color: #0b4f6c; font-size: 15px; font-weight: 700;">
                        👥 Speakers
                    </h3>
                    {% if session.speakers|length > 0 %}
                        <div style="display: grid; gap: 12px;">
                            {% for speaker in session.speakers %}
                                <div style="padding: 16px; border: 1px solid #e5e7eb; border-radius: 8px; background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); transition: all 0.2s;">
                                    <div style="display: flex; gap: 12px;">
                                        <div style="width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, #0b4f6c 0%, #136f92 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 16px; flex-shrink: 0;">
                                            {% set firstName = speaker.user.firstName %}
                                            {% set lastName = speaker.user.lastName %}
                                            {{ firstName[0] is defined ? firstName[0]|upper : '?' }}{{ lastName[0] is defined ? lastName[0]|upper : '?' }}
                                        </div>
                                        <div style="flex: 1;">
                                            <div style="font-weight: 700; color: #1f2937; font-size: 14px; margin-bottom: 4px;">{{ speaker.user.firstName }} {{ speaker.user.lastName }}</div>
                                            {% if speaker.jobTitle %}
                                                <div style="font-size: 13px; color: #0b4f6c; font-weight: 600; margin-bottom: 2px;">{{ speaker.jobTitle }}</div>
                                            {% endif %}
                                            {% if speaker.company %}
                                                <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px;">{{ speaker.company }}</div>
                                            {% endif %}
                                            {% if speaker.email %}
                                                <div style="font-size: 12px; color: #9ca3af;">📧 {{ speaker.email }}</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                    {% if speaker.bio %}
                                        <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #e5e7eb;">
                                            <div style="font-size: 13px; color: #4b5563; line-height: 1.5;">{{ speaker.bio }}</div>
                                        </div>
                                    {% endif %}
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div style="padding: 16px; border: 1px solid #e5e7eb; border-radius: 8px; background: #f8fafc; text-align: center; color: #9ca3af;">
                            No speakers assigned to this session
                        </div>
                    {% endif %}
                </div>

                <!-- Rooms Section -->
                <div>
                    <h3 style="margin: 0 0 12px 0; padding: 8px 12px; background: #f0f7ff; border-left: 4px solid #0b4f6c; border-radius: 4px; color: #0b4f6c; font-size: 15px; font-weight: 700;">
                        🏢 Rooms
                    </h3>
                    {% if session.rooms|length > 0 %}
                        <div style="display: grid; gap: 12px;">
                            {% for room in session.rooms %}
                                <div style="padding: 16px; border: 1px solid #e5e7eb; border-radius: 8px; background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); display: flex; gap: 12px; align-items: flex-start;">
                                    <div style="width: 44px; height: 44px; border-radius: 8px; background: linear-gradient(135deg, #0b4f6c 0%, #136f92 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 20px; flex-shrink: 0;">
                                        🏢
                                    </div>
                                    <div style="flex: 1;">
                                        <div style="font-weight: 700; color: #1f2937; font-size: 14px; margin-bottom: 4px;">{{ room.name }}</div>
                                        <div style="display: flex; gap: 16px; font-size: 13px;">
                                            <div><strong style="color: #0b4f6c;">Capacity:</strong> <span style="color: #6b7280;">{{ room.capacity }} people</span></div>
                                            {% if room.building %}
                                                <div><strong style="color: #0b4f6c;">Building:</strong> <span style="color: #6b7280;">{{ room.building }}</span></div>
                                            {% endif %}
                                            {% if room.floor %}
                                                <div><strong style="color: #0b4f6c;">Floor:</strong> <span style="color: #6b7280;">{{ room.floor }}</span></div>
                                            {% endif %}
                                        </div>
                                        {% if room.equipment %}
                                            <div style="margin-top: 6px; font-size: 12px; color: #6b7280;">Equipment: {{ room.equipment }}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div style="padding: 16px; border: 1px solid #e5e7eb; border-radius: 8px; background: #f8fafc; text-align: center; color: #9ca3af;">
                            No room assigned to this session
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Sidebar: Conference Information -->
            <div>
                <div style="padding: 20px; border: 1px solid #e5e7eb; border-radius: 12px; background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%); position: sticky; top: 100px;">
                    <h2 style="margin: 0 0 16px 0; color: #0b4f6c; font-size: 18px; font-weight: 700;">🏛️ Conference</h2>
                    
                    <div style="padding: 12px; background: #f0f7ff; border-left: 3px solid #0b4f6c; border-radius: 6px; margin-bottom: 16px;">
                        <h3 style="margin: 0; color: #0b4f6c; font-size: 14px; font-weight: 700;">{{ session.conference.name }}</h3>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 12px;">
                        <div>
                            <div style="font-size: 11px; font-weight: 700; color: #265f7d; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">📍 Location</div>
                            <div style="font-size: 13px; color: #1f2937;">{{ session.conference.location }}</div>
                        </div>

                        <div>
                            <div style="font-size: 11px; font-weight: 700; color: #265f7d; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">📅 Date Range</div>
                            <div style="font-size: 13px; color: #1f2937;">{{ session.conference.startDate|date('M d, Y') }} - {{ session.conference.endDate|date('M d, Y') }}</div>
                        </div>

                        <div>
                            <div style="font-size: 11px; font-weight: 700; color: #265f7d; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Status</div>
                            <span style="display: inline-block; padding: 4px 8px; border-radius: 4px; background: {% if session.conference.status == 'UPCOMING' %}#dbeafe{% elseif session.conference.status == 'ONGOING' %}#fef3c7{% else %}#dbeafe{% endif %}; color: {% if session.conference.status == 'UPCOMING' %}#0369a1{% elseif session.conference.status == 'ONGOING' %}#92400e{% else %}#0369a1{% endif %}; font-size: 12px; font-weight: 700;">
                                {{ session.conference.status }}
                            </span>
                        </div>

                        <div>
                            <div style="font-size: 11px; font-weight: 700; color: #265f7d; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">👥 Max Attendees</div>
                            <div style="font-size: 13px; color: #1f2937;">{{ session.conference.maxAttendees }}</div>
                        </div>
                    </div>

                    {% if session.conference.description %}
                        <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid #e5e7eb;">
                            <div style="font-size: 11px; font-weight: 700; color: #265f7d; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px;">About</div>
                            <div style="font-size: 12px; color: #4b5563; line-height: 1.5;">{{ session.conference.description }}</div>
                        </div>
                    {% endif %}

                    <a href="{{ path('app_conference_show', {id: session.conference.id}) }}" style="display: block; width: 100%; text-align: center; margin-top: 16px; padding: 10px 12px; background: linear-gradient(135deg, #0b4f6c 0%, #136f92 100%); color: white; text-decoration: none; border-radius: 8px; font-size: 13px; font-weight: 600; transition: all 0.2s; border: 1px solid #0b4f6c;">
                        View Full Conference →
                    </a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
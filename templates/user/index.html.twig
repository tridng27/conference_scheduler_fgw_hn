{% extends 'base.html.twig' %}

{% block title %}User Roles{% endblock %}

{% block body %}
<div class="card">
    <h1 style="margin-top: 0;">User Role Management</h1>
    <p style="color: var(--muted); margin-top: 4px;">
        Registered accounts are created from the public registration page as <strong>ROLE_USER</strong>.
        Promote or demote access here.
    </p>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Email</th>
                <th>Name</th>
                <th>Roles</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for listedUser in users %}
            {% set isAdmin = 'ROLE_ADMIN' in listedUser.roles %}
            {% set isSelf = app.user and app.user.id == listedUser.id %}
            <tr>
                <td>{{ listedUser.id }}</td>
                <td>{{ listedUser.email }}</td>
                <td>{{ listedUser.firstName }} {{ listedUser.lastName }}</td>
                <td>{{ listedUser.roles|join(', ') }}</td>
                <td>{{ listedUser.createdAt ? listedUser.createdAt|date('Y-m-d H:i') : '-' }}</td>
                <td>
                    <div class="actions">
                        {% if not isAdmin %}
                            <form class="inline" method="post" action="{{ path('app_user_promote', {id: listedUser.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('promote_user_' ~ listedUser.id) }}">
                                <button class="btn" type="submit">Promote to Admin</button>
                            </form>
                        {% else %}
                            <form class="inline" method="post" action="{{ path('app_user_demote', {id: listedUser.id}) }}" onsubmit="return confirm('Demote this admin to user?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('demote_user_' ~ listedUser.id) }}">
                                <button class="btn btn-danger" type="submit" {% if isSelf and admin_count <= 1 %}disabled{% endif %}>Demote Admin</button>
                            </form>
                            {% if isSelf and admin_count <= 1 %}
                                <span style="color: var(--muted);">Last admin cannot self-demote.</span>
                            {% endif %}
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="6">No users found.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

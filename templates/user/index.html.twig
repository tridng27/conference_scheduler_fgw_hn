{% extends 'base.html.twig' %}

{% block title %}Users{% endblock %}

{% block body %}
<div class="card">
    <div class="actions">
        <h1 style="margin: 0;">Users</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <a class="btn" href="{{ path('app_user_new') }}">New User</a>
        {% endif %}
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Email</th>
                <th>Name</th>
                <th>Roles</th>
                <th>Role Label</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.firstName }} {{ user.lastName }}</td>
                <td>{{ user.roles|join(', ') }}</td>
                <td>{{ user.role }}</td>
                <td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : '-' }}</td>
                <td>
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="actions">
                            <a class="btn btn-secondary" href="{{ path('app_user_edit', {id: user.id}) }}">Edit</a>
                            <form class="inline" method="post" action="{{ path('app_user_delete', {id: user.id}) }}" onsubmit="return confirm('Delete this user?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                <button class="btn btn-danger" type="submit">Delete</button>
                            </form>
                        </div>
                    {% else %}
                        <span style="color: var(--muted);">View only</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr><td colspan="7">No users found.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

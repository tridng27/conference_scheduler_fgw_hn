{% extends 'base.html.twig' %}

{% block title %}Admin{% endblock %}

{% block body %}
<div class="card">
    <h1>Admin Overview</h1>
    <p>Operational totals for quick monitoring.</p>

    <ul>
        <li>Total conferences: {{ stats.conferences }}</li>
        <li>Total sessions: {{ stats.sessions }}</li>
        <li>Total registrations: {{ stats.registrations }}</li>
        <li>Total users: {{ stats.users }}</li>
    </ul>
</div>
{% endblock %}

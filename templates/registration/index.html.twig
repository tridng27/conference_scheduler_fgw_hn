{% extends 'base.html.twig' %}

{% block title %}Registrations{% endblock %}

{% block body %}
<div class="card">
    <div class="actions">
        <h1 style="margin: 0;">Registrations</h1>
        <a class="btn" href="{{ path('app_registration_new') }}">New Registration</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Date</th>
                <th>Status</th>
                <th>Ticket</th>
                <th>Users</th>
                <th>Conferences</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for registration in registrations %}
            <tr>
                <td>{{ registration.id }}</td>
                <td>{{ registration.registrationDate ? registration.registrationDate|date('Y-m-d H:i') : '-' }}</td>
                <td>{{ registration.status }}</td>
                <td>{{ registration.ticketType ?? '-' }}</td>
                <td>{{ registration.users|length }}</td>
                <td>{{ registration.conferences|length }}</td>
                <td>
                    <div class="actions">
                        <a class="btn btn-secondary" href="{{ path('app_registration_edit', {id: registration.id}) }}">Edit</a>
                        <form class="inline" method="post" action="{{ path('app_registration_delete', {id: registration.id}) }}" onsubmit="return confirm('Delete this registration?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_registration_' ~ registration.id) }}">
                            <button class="btn btn-danger" type="submit">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="7">No registrations found.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

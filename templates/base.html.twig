<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Conference Scheduler{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>CS</text></svg>">

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        <style>
            :root {
                color-scheme: light;
                --primary: #0b4f6c;
                --accent: #ffb703;
                --surface: #ffffff;
                --bg: #f2f5f9;
                --text: #1f2937;
                --muted: #64748b;
                --border: #d9e2ec;
            }
            body {
                margin: 0;
                font-family: "Trebuchet MS", "Segoe UI", sans-serif;
                background:
                    radial-gradient(circle at 10% 10%, #fff8e6 0, #fff8e6 18%, transparent 19%),
                    linear-gradient(150deg, #eaf2ff 0%, #f7fbff 40%, #fefcf6 100%);
                color: var(--text);
            }
            .topbar {
                background: linear-gradient(110deg, #08344a, #0b4f6c 55%, #136f92);
                color: #fff;
                padding: 12px 20px;
                display: flex;
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 10px;
                align-items: center;
                border-bottom: 4px solid var(--accent);
            }
            .nav-links,
            .auth-links {
                display: flex;
                flex-wrap: wrap;
                gap: 8px;
                align-items: center;
            }
            .topbar a,
            .auth-pill {
                color: #eef7ff;
                text-decoration: none;
                font-size: 14px;
                padding: 6px 10px;
                border-radius: 999px;
                border: 1px solid transparent;
            }
            .topbar a:hover,
            .auth-pill:hover {
                background: rgba(255, 255, 255, 0.12);
                border-color: rgba(255, 255, 255, 0.3);
            }
            .container {
                max-width: 1200px;
                margin: 24px auto;
                padding: 0 16px;
            }
            .card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 14px;
                box-shadow: 0 8px 24px rgba(8, 52, 74, 0.08);
                padding: 20px;
                margin-bottom: 16px;
            }
            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
                gap: 12px;
            }
            .metric {
                background: linear-gradient(150deg, #ffffff 0%, #eef7ff 100%);
                border: 1px solid #c8dff0;
                border-radius: 10px;
                padding: 14px;
            }
            .metric .label {
                font-size: 12px;
                color: #265f7d;
            }
            .metric .value {
                font-size: 24px;
                font-weight: 700;
            }
            table {
                width: 100%;
                border-collapse: collapse;
                margin-top: 12px;
            }
            th, td {
                text-align: left;
                padding: 10px;
                border-bottom: 1px solid var(--border);
                font-size: 14px;
                vertical-align: top;
            }
            th {
                color: #274c63;
            }
            .btn {
                display: inline-block;
                border: 1px solid #0b4f6c;
                background: #0b4f6c;
                color: #fff;
                text-decoration: none;
                border-radius: 8px;
                font-size: 13px;
                padding: 7px 10px;
                cursor: pointer;
            }
            .btn.btn-secondary {
                background: #fff;
                color: #0b4f6c;
            }
            .btn.btn-danger {
                border-color: #dc2626;
                background: #dc2626;
            }
            .btn:hover {
                opacity: 0.95;
            }
            .actions {
                display: flex;
                gap: 8px;
                align-items: center;
                flex-wrap: wrap;
            }
            form.inline {
                display: inline;
            }
            .flash {
                border-radius: 6px;
                padding: 10px 12px;
                margin-bottom: 10px;
                font-size: 14px;
            }
            .flash-success {
                background: #dcfce7;
                color: #166534;
                border: 1px solid #86efac;
            }
            .flash-error {
                background: #fee2e2;
                color: #991b1b;
                border: 1px solid #fca5a5;
            }
            label {
                display: block;
                margin: 10px 0 6px;
                color: #1f4154;
                font-weight: 600;
                font-size: 13px;
            }
            input, select, textarea {
                width: 100%;
                max-width: 100%;
                box-sizing: border-box;
                border: 1px solid #b8d1e2;
                border-radius: 8px;
                padding: 9px 10px;
                background: #fff;
                font: inherit;
                margin-bottom: 8px;
            }
            input:focus, select:focus, textarea:focus {
                outline: 2px solid #b5d6ea;
                border-color: #0b4f6c;
            }
            .auth-card {
                max-width: 520px;
                margin: 40px auto;
            }
            @media (max-width: 720px) {
                .topbar {
                    padding: 10px 12px;
                }
                .container {
                    margin: 14px auto;
                    padding: 0 10px;
                }
                th, td {
                    font-size: 12px;
                    padding: 8px;
                }
            }
        </style>
    </head>
    <body>
        <nav class="topbar">
            <div class="nav-links">
                {% if app.user %}
                    <a href="{{ path('app_home') }}">Dashboard</a>
                    <a href="{{ path('app_conference_index') }}">Conferences</a>
                    <a href="{{ path('app_session_index') }}">Sessions</a>
                    <a href="{{ path('app_speaker_index') }}">Speakers</a>
                    <a href="{{ path('app_venue_index') }}">Venues</a>
                    <a href="{{ path('app_room_index') }}">Rooms</a>
                    <a href="{{ path('app_registration_index') }}">Registrations</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_user_index') }}">Users</a>
                    {% endif %}
                {% endif %}
            </div>
            <div class="auth-links">
                {% if app.user %}
                    <span class="auth-pill">{{ app.user.userIdentifier }}</span>
                    <a href="{{ path('app_profile') }}">Profile</a>
                    <a href="{{ path('app_logout') }}">Logout</a>
                {% else %}
                    <a href="{{ path('app_login') }}">Login</a>
                    <a href="{{ path('app_register') }}">Register</a>
                {% endif %}
            </div>
        </nav>

        <main class="container">
            {% for message in app.flashes('success') %}
                <div class="flash flash-success">{{ message }}</div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div class="flash flash-error">{{ message }}</div>
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>

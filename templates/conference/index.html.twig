{% extends 'base.html.twig' %}

{% block title %}Conferences{% endblock %}

{% block body %}
<div class="card">
    <div class="actions">
        <h1 style="margin: 0;">Conferences</h1>
        <a class="btn" href="{{ path('app_conference_new') }}">New Conference</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Location</th>
                <th>Dates</th>
                <th>Status</th>
                <th>Max</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for conference in conferences %}
            <tr>
                <td>{{ conference.id }}</td>
                <td>{{ conference.name }}</td>
                <td>{{ conference.location }}</td>
                <td>{{ conference.startDate ? conference.startDate|date('Y-m-d H:i') : '-' }} to {{ conference.endDate ? conference.endDate|date('Y-m-d H:i') : '-' }}</td>
                <td>{{ conference.status }}</td>
                <td>{{ conference.maxAttendees }}</td>
                <td>{{ conference.active ? 'Yes' : 'No' }}</td>
                <td>
                    <div class="actions">
                        <a class="btn btn-secondary" href="{{ path('app_conference_edit', {id: conference.id}) }}">Edit</a>
                        <form class="inline" method="post" action="{{ path('app_conference_delete', {id: conference.id}) }}" onsubmit="return confirm('Delete this conference?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_conference_' ~ conference.id) }}">
                            <button class="btn btn-danger" type="submit">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="8">No conferences found.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
